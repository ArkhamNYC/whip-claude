{
  "name": "whip-claude",
  "version": "0.1.0",
  "description": "Crack a whip at Claude to make it work faster. A novelty CLI + /whip slash command for Claude Code.",
  "type": "module",
  "bin": {
    "whip-claude": "./dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "prepack": "npm run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "whip",
    "vibe-coding",
    "ascii-art",
    "terminal",
    "slash-command",
    "tui"
  ],
  "author": "Adrian Kehlmann <adriankehlmann@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ArkhamNYC/whip-claude#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ArkhamNYC/whip-claude.git"
  },
  "bugs": {
    "url": "https://github.com/ArkhamNYC/whip-claude/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.2.1",
    "chalk": "^5.3.0",
    "cli-cursor": "^5.0.0",
    "commander": "^12.1.0",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.9.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
